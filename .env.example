# =========================
# OpenAI 兼容 LLM 配置
# =========================
LLM_MODEL=qwen-plus
LLM_API_KEY=your_openai_compatible_api_key
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# 多智能体可分别指定模型（未设置则回退到 LLM_MODEL）
COORDINATOR_MODEL=
RETRIEVAL_MODEL=
WRITER_MODEL=
MANAGER_MODEL=

# =========================
# 可选：后端/前端配置
# =========================
BACKEND_URL=http://127.0.0.1:5000
FLASK_HOST=127.0.0.1
FLASK_PORT=5000
FLASK_DEBUG=false
GRADIO_SERVER_NAME=127.0.0.1
GRADIO_SERVER_PORT=7860
GRADIO_SHARE=false
MAX_UPLOAD_MB=50

# =========================
# Embedding 配置（OpenAI 兼容 embeddings 接口）
# =========================
EMBEDDING_MODEL=text-embedding-v4
EMBEDDING_API_KEY=your_embedding_api_key
EMBEDDING_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
EMBEDDING_TIMEOUT=30
EMBEDDING_MAX_RETRIES=2
EMBEDDING_RETRY_BACKOFF=1.6

# 通义兼容 embeddings 常见限制：单次 batch <= 10
EMBEDDING_BATCH_SIZE=10

# =========================
# Grobid 服务地址（必须）
# =========================
GROBID_URL=http://localhost:8070

# =========================
# 项目运行参数
# =========================
PAPERS_DIR=./papers
CHROMA_DIR=./chroma_db
OUTPUT_DIR=./outputs
CHROMA_COLLECTION=pdf_rag_demo
TOP_K=4

# 父子切分参数：父块用于返回上下文，子块用于向量检索
CHUNK_SIZE=1500
CHUNK_OVERLAP=150
CHILD_CHUNK_SIZE=300
CHILD_CHUNK_OVERLAP=80

DEMO_QUESTION=总结一下目前关于大模型在 RAG 系统中的应用方法。
